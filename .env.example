# Conta remetente usada pelo Outlook Classic COM.
OUTLOOK_COM_SENDER_EMAIL="nilvanlopes@outlook.com"

# Destinatário que recebe a cópia de revisão quando apply --send é usado.
# O destinatário final da empresa fica salvo nos artefatos para o comando send.
JOB_APPLICATION_REVIEW_EMAIL="pyuloko7@gmail.com"

# Currículo base usado quando --resume-file não é informado.
JOB_APPLICATION_DEFAULT_RESUME="/mnt/c/Users/pyu/OneDrive/Documentos/Obsidian/dev/Curriculo.md"

# Checkout do curriculum-optimizer chamado durante a geração do PDF.
JOB_APPLICATION_OPTIMIZER_ROOT="/home/pyu/docker/curriculum-optimizer"

# Endpoint da API nativa do Ollama. Mantenha o sufixo /api.
JOB_APPLICATION_OLLAMA_BASE_URL="http://localhost:11434/api"

# Modelos usados nas etapas de IA.
JOB_APPLICATION_OLLAMA_MODEL="qwen2.5:7b"
JOB_APPLICATION_OLLAMA_EMAIL_ANALYSIS_MODEL="qwen3.5:9b"
JOB_APPLICATION_OLLAMA_EMAIL_MODEL="qwen2.5:14b-instruct-q3_K_M"

# Docker Compose usado para gerenciar o Ollama.
# Se vazio, o projeto prefere /home/pyu/docker/ollama/docker-compose.yml quando existir;
# caso contrário usa docker-compose.ollama.yml deste repo.
# Use "false" para desabilitar compose mesmo com gerenciamento ativo.
JOB_APPLICATION_OLLAMA_COMPOSE_FILE=""

# Liga/desliga o gerenciamento automático do serviço Ollama.
# Se false, o Ollama precisa estar online antes da execução.
JOB_APPLICATION_OLLAMA_MANAGE_SERVICE="true"

# Derruba o compose no final somente quando o fluxo tiver subido o serviço.
JOB_APPLICATION_OLLAMA_SHUTDOWN_WHEN_DONE="true"

# Baixa modelos ausentes automaticamente via ollama pull.
JOB_APPLICATION_OLLAMA_PULL_MODEL_WHEN_MISSING="true"

# Tempo máximo de espera pelo Ollama após subir o container.
JOB_APPLICATION_OLLAMA_STARTUP_TIMEOUT_SECONDS="180"

# Intervalo entre tentativas enquanto espera o Ollama ficar pronto.
JOB_APPLICATION_OLLAMA_POLL_INTERVAL_SECONDS="2"

# Nome do volume usado pelo docker-compose.ollama.yml local.
JOB_APPLICATION_OLLAMA_VOLUME="ollama_ollama-data"
