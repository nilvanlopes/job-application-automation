{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug candidatura por imagem",
      "type": "python",
      "request": "launch",
      "module": "job_application_automation",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "JOB_APPLICATION_OLLAMA_MANAGE_SERVICE": "false"
      },
      "args": [
        "apply",
        "--job-image",
        "/home/pyu/.hermes/images/clip_20260716_212542_1.png",
        "--send"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
